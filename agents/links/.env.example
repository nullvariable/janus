# Links agent environment variables.
#
# Real values go in /agents/links/.env on the host
# (e.g. ~/projects/links-agent/.env), which janus's entrypoint sources into
# the launch shell before running `hermes --tui`. Hermes resolves ${VAR}
# references in config.yaml from this env.

# Mattermost bot the agent posts as.
MATTERMOST_URL=
MATTERMOST_BOT_TOKEN=
MATTERMOST_CHANNEL_ID=

# Required for the hermes runtime — model is routed via Ollama Cloud.
# Hermes looks for OLLAMA_API_KEY by convention; if you have your key stored
# elsewhere (e.g. OLLAMA_CLOUD_API_KEY), paste the same value here under the
# canonical name.
OLLAMA_API_KEY=
