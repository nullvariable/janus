{
  "mcpServers": {
    "mattermost": {
      "command": "/home/node/.bun/bin/bun",
      "args": ["/app/mattermost-channel/server.ts"],
      "env": {
        "MATTERMOST_URL": "https://your-mattermost-host.example.com",
        "MATTERMOST_BOT_TOKEN": "REPLACE_WITH_GEORDI_BOT_TOKEN",
        "MATTERMOST_CHANNEL_ID": "REPLACE_WITH_GEORDI_CHANNEL_ID"
      }
    },
    "heartbeat": {
      "command": "/home/node/.bun/bin/bun",
      "args": ["/app/heartbeat/server.ts"],
      "env": {
        "HEARTBEAT_FILE": "/agents/geordi/HEARTBEAT.md",
        "HEARTBEAT_INTERVAL_MINUTES": "30",
        "HEARTBEAT_JITTER_MINUTES": "2"
      }
    }
  }
}
