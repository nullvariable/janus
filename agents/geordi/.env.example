# Geordi agent environment variables
# Copy to .env and fill in values

# Planka — point at wherever your Planka instance lives. If it's on the same
# Docker host, you can use http://host.docker.internal:1337 (extra_hosts in
# docker-compose.yml already maps host.docker.internal). If it's on a
# different host, use that host's IP/DNS name.
PLANKA_URL=http://host.docker.internal:1337
PLANKA_GEORDI_TOKEN=your-planka-token
